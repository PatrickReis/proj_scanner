# ── Modo de operação ──────────────────────────────────────────────────────────
# "org"  → lista todos os repos de uma organização (requer GITHUB_ORG)
# "user" → lista todos os repos do workspace pessoal (requer GITHUB_USER ou token owner)
SOURCE_TYPE=org

# ── GitHub Config ─────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_ORG=nome-da-sua-organizacao
GITHUB_USER=

# ── Branch alvo para o clone ──────────────────────────────────────────────────
TARGET_BRANCH=release

# ── Comportamento da execução ─────────────────────────────────────────────────
# true  → apaga DOWNLOAD_DIR no início de cada run (padrão)
# false → reutiliza downloads existentes (útil para re-rodar só a varredura)
CLEAN_RUN=true

# ── Paths (opcionais) ─────────────────────────────────────────────────────────
DOWNLOAD_DIR=./downloads
OUT_DIR=./out
OUTPUT_FILE=./out/resultado_varredura.csv
DLQ_FILE=./out/dlq_release.csv

REPO_FILTER="regex-name1 ,exp2"
